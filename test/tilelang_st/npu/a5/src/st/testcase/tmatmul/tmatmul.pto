    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID0"]
    pto.mte_l1_l0a %l1_a, %l0a, %c144_i64, %c80_i64, %c0_i64, %c0_i64
      : !pto.ptr<bf16, l1>, !pto.ptr<bf16, l0a>, i64, i64, i64, i64

    pto.mte_gm_l1_frac %b_gm, %l1_b, nd2nz,
      shape(%c80_i64, %c48_i64), src_layout(%c96_i64),
      dst_group(%c1_i64, %c1_i64, %c80_i64, %c0_i64),
      ctrl(%c0_i64, %false)
      : !pto.ptr<bf16, gm>, !pto.ptr<bf16, l1>, nd2nz,
        shape i64, i64, src_layout(i64),
        dst_group i64, i64, i64, i64, ctrl i64, i1
    pto.set_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID1"]
    pto.wait_flag["PIPE_MTE2", "PIPE_MTE1", "EVENT_ID1"]
    pto.mte_l1_l0b %l1_b, %l0b, %c80_i64, %c48_i64, %c0_i64, %c0_i64 {transpose = true}
      : !pto.ptr<bf16, l1>, !pto.ptr<bf16, l0b>, i64, i64, i64, i64

    pto.set_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.wait_flag["PIPE_MTE1", "PIPE_M", "EVENT_ID0"]
    pto.tmatmul ins(%l0a_tile, %l0b_tile : !pto.tile_buf<left, 144x80xbf16, blayout=col_major, slayout=row_major>,
                                         !pto.tile_buf<right, 80x48xbf16, blayout=row_major, slayout=col_major>)
                outs(%l0c_tile : !pto.tile_buf<acc, 144x48xf32, blayout=col_major, slayout=row_major, fractal=1024>)

