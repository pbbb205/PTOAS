// RUN: env PTOAS_DEBUG_CHILD_UNIT=1 ptoas %s -o %t.o 2>&1 | FileCheck %s
// Guards child-unit wrapper synthesis: only PTODSL symbols with explicit
// logical-name attrs may be rewritten to logical wrappers.

module attributes {pto.target_arch = "a5"} {
  module attributes {pto.backend = "emitc"} {
    func.func private @helper__ptodsl_user()

    func.func @entry() attributes {pto.entry} {
      func.call @helper__ptodsl_user() : () -> ()
      return
    }
  }

  module attributes {pto.backend = "emitc"} {
    func.func public @helper() {
      return
    }

    func.func public @helper__ptodsl_user() {
      return
    }
  }
}

// CHECK: func.func public @helper() {
// CHECK-NEXT:   return
// CHECK-NEXT: }
// CHECK: func.func public @helper__ptodsl_user() {
// CHECK-NEXT:   return
// CHECK-NEXT: }
