// RUN: ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s
// RUN: ptoas --pto-arch=a5 %s 2>&1 | FileCheck %s

module attributes {"pto.device-spec" = "Ascend910B3"} {
  func.func @texpands_bf16_vec(%scalar: bf16) attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %dst = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=bf16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.texpands ins(%scalar : bf16)
                 outs(%dst : !pto.tile_buf<loc=vec, dtype=bf16, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    return
  }

  func.func @texpands_bf16_mat(%scalar: bf16) attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %dst = pto.alloc_tile : !pto.tile_buf<loc=mat, dtype=bf16, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=512, pad=0>

    pto.texpands ins(%scalar : bf16)
                 outs(%dst : !pto.tile_buf<loc=mat, dtype=bf16, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=512, pad=0>)

    return
  }
}

// CHECK-LABEL: AICORE void texpands_bf16_vec(
// CHECK:       Tile<TileType::Vec, bfloat16_t
// CHECK:       TEXPANDS(

// CHECK-LABEL: AICORE void texpands_bf16_mat(
// CHECK:       Tile<TileType::Mat, bfloat16_t
// CHECK:       TEXPANDS(
